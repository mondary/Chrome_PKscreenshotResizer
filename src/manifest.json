{
  "manifest_version": 3,
  "name": "PK Screenshot Resizer",
  "version": "2.5",
  "description": "Resize windows & capture screenshots. Made by PK-Labs.",
  "short_name": "PK-Labs Shot",
  "permissions": [
    "windows",
    "activeTab",
    "downloads"
  ],
  "action": {
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Take Screenshot"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
